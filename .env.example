LLM_PROVIDER=none
LLM_MODEL=
LLM_API_BASE=
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=60

QUERY_REWRITE_LLM_PROVIDER=
QUERY_REWRITE_LLM_MODEL=
QUERY_REWRITE_LLM_API_BASE=
QUERY_REWRITE_LLM_API_KEY=
QUERY_REWRITE_LLM_TIMEOUT_SECONDS=

QUERY_TRANSFORM_LLM_PROVIDER=
QUERY_TRANSFORM_LLM_MODEL=
QUERY_TRANSFORM_LLM_API_BASE=
QUERY_TRANSFORM_LLM_API_KEY=
QUERY_TRANSFORM_LLM_TIMEOUT_SECONDS=

GENERATION_LLM_PROVIDER=
GENERATION_LLM_MODEL=
GENERATION_LLM_API_BASE=
GENERATION_LLM_API_KEY=
GENERATION_LLM_TIMEOUT_SECONDS=

INGESTION_LLM_PROVIDER=
INGESTION_LLM_MODEL=
INGESTION_LLM_API_BASE=
INGESTION_LLM_API_KEY=
INGESTION_LLM_TIMEOUT_SECONDS=

EVALUATION_LLM_PROVIDER=
EVALUATION_LLM_MODEL=
EVALUATION_LLM_API_BASE=
EVALUATION_LLM_API_KEY=
EVALUATION_LLM_TIMEOUT_SECONDS=
# Comma-separated browser origins allowed to call the FastAPI backend.
# Example: https://your-frontend.ngrok-free.app
CORS_ALLOW_ORIGINS=

# Example local HTTP model endpoint:
#   LLM_PROVIDER=ollama
#   LLM_MODEL=qwen3.5:9b-q4_K_M
#   LLM_API_BASE=http://127.0.0.1:11434

# Evidence provider used when the frontend does not send evidence chunks directly.
# Options:
#   mock    - demo fixtures only
#   ragflow - use RAGFlow retrieval chunks, then generate/cite in this app
#   local_pdf - use local PDF/URL/text ingestion/chunks/retrieval, then generate/cite here
EVIDENCE_PROVIDER=local_pdf

# Local source provider. Keeps RAGFlow as a switchable baseline while letting the
# app run the internal PDF, URL, and text ingestion/retrieval path first.
LOCAL_PDF_STORE_DIR=storage/local_pdf
# PDF parser pipeline selection. LOCAL_PDF_PARSER is kept as a legacy alias for
# LOCAL_PDF_STRATEGY during the transition.
LOCAL_PDF_PIPELINE=ocr
LOCAL_PDF_STRATEGY=docling
LOCAL_PDF_PARSER=docling
LOCAL_PDF_CHUNKER=deterministic
LOCAL_PDF_RETRIEVAL_TOP_K=20
LOCAL_PDF_RETRIEVAL_CANDIDATE_K=20
# Persistent source storage. Options: jsonl (default, no DB needed) | postgres | s3
# Use s3 for cloud source/artifact storage. Use postgres for team/deploy chunk
# metadata when raw files should still stay under LOCAL_PDF_STORE_DIR.
LOCAL_SOURCE_STORE=jsonl
# Example local:   postgresql+psycopg://postgres:postgres@localhost:5433/agentic_rag
# Example Supabase: postgresql+psycopg://user:pass@host:6543/postgres
LOCAL_SOURCE_POSTGRES_CONNECTION=
LOCAL_SOURCE_POSTGRES_TABLE_PREFIX=local_rag
# Required when LOCAL_SOURCE_STORE=s3.
AWS_REGION=
AWS_S3_BUCKET=
AWS_S3_PREFIX=agentic-rag/sources
AWS_PROFILE=agentic-rag

# RAGFlow baseline/fallback integration. RAGFlow runs as a separate service; this
# app uses its document/chunk/retrieval APIs instead of its all-in-one chat answer.
RAGFLOW_BASE_URL=http://127.0.0.1:9380
RAGFLOW_API_KEY=
RAGFLOW_DATASET_ID=
RAGFLOW_TIMEOUT_SECONDS=60
RAGFLOW_PAGE_SIZE=5
RAGFLOW_SIMILARITY_THRESHOLD=0.2
RAGFLOW_VECTOR_SIMILARITY_WEIGHT=0.3
RAGFLOW_TOP_K=1024
RAGFLOW_KEYWORD=false

# Retrieval fusion/rerank. Keep `score` for lightweight local runs; use
# `sentence_transformers` after installing the local-models extra.
# Set RERANK_PRELOAD=true to load the local reranker during API startup instead
# of waiting for the first real question.
RERANK_PROVIDER=score
RERANK_MODEL=
RERANK_API_BASE=
RERANK_API_KEY=
RERANK_TIMEOUT_SECONDS=60
RERANK_PRELOAD=false
# Options: auto, cpu, cuda, mps. Use cuda only after installing CUDA-enabled
# PyTorch, and mps only on supported macOS Apple Silicon setups.
RERANK_DEVICE=auto
FUSION_METHOD=rrf
FUSION_RRF_K=60
FUSION_BM25_WEIGHT=0.55
FUSION_DENSE_WEIGHT=0.45
FUSION_NORMALIZED_ALPHA=0.55
BM25_MIN_SCORE=
DENSE_MIN_SCORE=
BM25_MIN_NORM_SCORE=
DENSE_MIN_NORM_SCORE=
FUSION_MIN_SCORE=
RERANK_MIN_SCORE=
MIN_EVIDENCE_COUNT=0

# Dense embedding provider. `huggingface` runs in process after installing
# local-models; other providers route through LiteLLM.
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_API_BASE=
EMBEDDING_API_KEY=
EMBEDDING_DIMENSIONS=
EMBEDDING_TIMEOUT_SECONDS=60
# Options: auto, cpu, cuda, mps. Use cuda on compatible NVIDIA Windows/Linux
# machines, and mps only on supported macOS Apple Silicon setups.
EMBEDDING_DEVICE=auto
# Vector store options: turbovec (local), pgvector, qdrant.
DENSE_VECTOR_STORE=turbovec
DENSE_PGVECTOR_CONNECTION=
DENSE_PGVECTOR_COLLECTION=agentic_rag_chunks
QDRANT_URL=
QDRANT_API_KEY=
# One collection must contain only one embedding provider/model/dimension
# profile. Change the name or delete and reindex when switching models.
QDRANT_COLLECTION=agentic_rag_chunks

# Agentic RAG — Self-RAG with LangGraph.
# Set AGENT_MODE=true to route /answer through the Self-RAG pipeline.
# Linear pipeline is used when AGENT_MODE=false (default).
AGENT_MODE=false
# Max retrieval+transform loops before forcing generate.
AGENT_MAX_STEPS=3
# Top-N candidates passed to final rerank.
AGENT_RERANK_FINAL_TOP_K=15
AGENT_RERANK_MULTI_TOP_K=10
# Max times to regenerate if answer is hallucinated.
AGENT_MAX_GENERATE_ATTEMPTS=2

# Optional trace log for debugging/evaluation.
RAG_TRACE_ENABLED=true
# Options: jsonl, langsmith, both
RAG_TRACE_PROVIDER=both
RAG_TRACE_PATH=logs/rag_runs.jsonl
RAG_TRACE_FULL_CONTENT=false
RAG_TRACE_PREVIEW_CHARS=4000

# LangSmith is optional. Install with: pip install -e ".[observability]"
# RAG_TRACE_PROVIDER options: jsonl, langsmith, both.
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=agentic-rag-group1
# langgraph: native graph view (recommended when AGENT_MODE=true)
# custom: rag-answer chain view (recommended when AGENT_MODE=false)
LANGSMITH_TRACE_MODE=custom

# LangGraph native tracing — set LANGCHAIN_API_KEY = same as LANGSMITH_API_KEY
# Only needed when LANGSMITH_TRACE_MODE=langgraph
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=agentic-rag-group1

# HuggingFace offline mode — set to 1 to use cached models without network
# Useful when cross-encoder reranker is already downloaded
HF_HUB_OFFLINE=0
HF_TOKEN=
